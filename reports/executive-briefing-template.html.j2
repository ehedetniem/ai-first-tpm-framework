<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ data.title }}</title>
  <style>{{ theme_css }}</style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1 class="title">{{ data.title }}</h1>
      <p class="subtitle">Week Ending: {{ data.weekEnding }} | Owner: {{ data.owner }}</p>
    </div>

    <div class="section">
      <h2>Leadership Summary</h2>
      <p><strong>Top Win:</strong> {{ data.topWin }}</p>
      <p><strong>Top Risk:</strong> {{ data.topRisk }}</p>
      <p><strong>Decision Needed:</strong> {{ data.decisionNeeded }}</p>
    </div>

    <div class="section">
      <h2>Program Health Snapshot</h2>
      <table class="table">
        <tr><th>Program</th><th>Health</th><th>Trend</th></tr>
        {% for row in data.programSummary %}
        <tr>
          <td>{{ row.program }}</td>
          <td>{{ row.health }}</td>
          <td>{{ row.trend }}</td>
        </tr>
        {% endfor %}
      </table>
    </div>

    <div class="section">
      <h2>Leadership Asks</h2>
      <ul>
        {% for ask in data.asks %}
        <li>{{ ask }}</li>
        {% endfor %}
      </ul>
    </div>

    <div class="footer">Generated by AI-First TPM Framework. Human approval required before distribution.</div>
  </div>
</body>
</html>
